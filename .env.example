APP_NAME=personal-ai-os
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/personal_ai_os
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=personal_ai_os_memories

OBSIDIAN_HOST_PATH=./data/obsidian
OBSIDIAN_VAULT_PATH=/data/obsidian

MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMPAT_API_KEY=EMPTY
OPENAI_COMPAT_API_KEYS=
PROVIDER_TIMEOUT_SECONDS=120
PROVIDER_RETRY_ATTEMPTS=1
HF_ENDPOINT=https://hf-mirror.com
HF_TOKEN=
OPENWEBUI_RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENWEBUI_RAG_EMBEDDING_MODEL_AUTO_UPDATE=true
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=384

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder

EMBEDDING_PROVIDER=mock
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
